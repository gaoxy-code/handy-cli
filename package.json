{
  "name": "@gaoxy-code/handy-cli",
  "version": "0.1.1",
  "description": "Handy mini CLI tools (version / uuid / slug) - GitHub Packages publish study",
  "type": "module",
  "bin": {
    "handy": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gaoxy-code/handy-cli.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "allowScripts": {
    "esbuild@0.27.7": true
  }
}
